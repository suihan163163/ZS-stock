{
  "name": "product-management",
  "version": "1.0.0",
  "description": "Product management system with image upload functionality",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:css": "tailwindcss -i ./input.css -o ./tailwind.css",
    "watch:css": "tailwindcss -i ./input.css -o ./tailwind.css --watch",
    "dev": "concurrently \"nodemon server.js\" \"npm run watch:css\""
  },
  "keywords": [
    "express",
    "multer",
    "file-upload",
    "product-management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tailwindcss": "^3.4.19"
  }
}
